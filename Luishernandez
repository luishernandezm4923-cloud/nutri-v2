          <div class="ref-row"><span class="badge bs">Sobrepeso</span><span style="font-family:var(--mono);color:var(--t4);font-size:.76rem">IMC 25 – 29.9</span></div>
          <div class="ref-row"><span class="badge bo">Obesidad</span><span style="font-family:var(--mono);color:var(--t4);font-size:.76rem">IMC ≥ 30</span></div>
          <div style="margin-top:10px;background:var(--teal-50);border-radius:var(--r-sm);padding:8px 10px;font-size:.68rem;color:var(--teal-700);font-family:var(--mono)">WHtR normal: &lt; 0.5 · Riesgo: ≥ 0.5 · Criterios MINSA 2023</div>
