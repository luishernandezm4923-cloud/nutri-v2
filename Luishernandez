  try{
    const r=await fetch(`${SHEET_URL}?action=login&email=${encodeURIComponent(email)}&pass=${encodeURIComponent(pass)}&t=${Date.now()}`);
    const d=await r.json(); unspin();
    if(d.ok){ modo=d.rol||"salud"; user={email:d.email||email,rol:d.rol,nombre:d.nombre||email}; enterApp(modo==="salud"?"Personal de Salud":"UGEL Pisco"); }
    else fallback(email,pass,err);
  }catch{ unspin(); fallback(email,pass,err); }
}
function fallback(email,pass,err){
  const C=[{e:"salud@feliperenan.edu.pe",p:"salud123",rol:"salud",nombre:"Personal de Salud"},{e:"ugel@pisco.gob.pe",p:"ugel123",rol:"ugel",nombre:"UGEL Pisco"}];
