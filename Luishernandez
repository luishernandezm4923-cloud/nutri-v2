function abrirMed(id){
  const a=DATA.find(x=>x.id===id); if(!a) return; cur=a;
  $("mMedT").textContent="Nueva Medición";
  $("mMedS").textContent=a.nombre+" · IMC y WHtR se calculan automáticamente";
  $("mPeso").value=a.peso||""; $("mTalla").value=a.talla||"";
  $("mCin").value=a.cintura_cm||""; $("mFecha").value=hoy();
  prevMed(); openM("mMed");
}

function prevMed(){
  const p=parseFloat($("mPeso").value), t=parseFloat($("mTalla").value);
  const c=parseFloat($("mCin").value)||null, el=$("medPrev");
  if(p>0&&t>0){
    const imc=calcIMC(p,t), est=calcEstado(imc), eb=eBase(est);
    const whtr=c?calcWHTR(c,t):null, col=EC(eb);
    const bg={Normal:"var(--green-50)","Bajo Peso":"var(--amber-50)",Sobrepeso:"var(--orange-100)",Obesidad:"var(--red-50)"}[eb]||"var(--bg)";
    $("medPrevV").textContent=imc; $("medPrevV").style.color=col;
    $("medPrevE").textContent=est; $("medPrevE").style.color=col;
    $("medPrevW").textContent=whtr?`WHtR: ${whtr} · ${whtr>=0.5?"⚠ Riesgo abdominal":"Sin riesgo"}`:"";
    el.style.cssText=`display:block;background:${bg};border-color:${col}`;
  } else el.style.display="none";
}

async function saveMed(){
  if(!cur) return;
  const p=parseFloat($("mPeso").value), t=parseFloat($("mTalla").value);
  const c=parseFloat($("mCin").value)||null, f=$("mFecha").value;
  if(!p||!t||!f){ toast("Complete peso, talla y fecha"); return; }

  // Calcular en frontend (el servidor también recalcula — doble garantía)
  const imc   = calcIMC(p,t);
  const whtr  = c?calcWHTR(c,t):null;
  const est   = calcEstado(imc);

  spin("Guardando en Google Sheet…");
  let savedOk = false;
  try{
    const r=await fetch(SHEET_URL,{
      method:"POST",
      headers:{"Content-Type":"text/plain"},
      body:JSON.stringify({
        action:"nuevaMedicion",
        id_alumno:cur.id, nombre:cur.nombre, grado:cur.grado, seccion:cur.seccion,
        fecha:f, peso:p, talla:t, cintura_cm:c, usuario:user.email
        // imc/whtr/estado NO enviamos — el servidor los calcula frescos
      })
    });
    const d=await r.json(); unspin();
    savedOk=d.ok;
    toast(d.ok?"Medición guardada en Google Sheet ✓":"Error: "+(d.error||"respuesta inesperada del servidor"));
  }catch(e){
    unspin();
    toast(isDemo?"Guardado en demo (sin conexión)":"Error de red — verifique que la URL del script sea correcta");
  }

  // Actualizar estado local siempre (independiente del Sheet)
  Object.assign(cur,{peso:p,talla:t,imc,cintura_cm:c,whtr,estado:est,eb:eBase(est),recomendacion:autoRec(est,cur.nombre)});
  cur.historial.push({fecha:f,peso:p,talla:t,imc,estado:est});
  closeM("mMed"); verDet(cur.id); renderDash();
}

// ── REPORTE WHATSAPP ──────────────────────────────────────
function openRep(){
  if(!cur) return; const a=cur;
  const urg=a.eb==="Obesidad"||(a.imc>0&&a.imc<14);
  const msg=urg
    ?`⚠️ ATENCIÓN URGENTE — NutriCheck Escolar\n\nEstimado/a ${a.apoderado}:\n\nSu hijo/a ${a.nombre} (${a.grado}, Sección ${a.seccion}) presenta ${a.estado} según la evaluación nutricional.\n\n📊 IMC: ${a.imc}${a.whtr?` · WHtR: ${a.whtr}`:""}\n\n${a.recomendacion}\n\n📍 Centro de Salud San Andrés, Pisco\n🔖 Presente este mensaje en recepción.\n\n— I.E. Cap. FAP Renán Elías Olivera · Programa NutriCheck`
    :`Estimado/a ${a.apoderado}:\n\nSu hijo/a ${a.nombre} fue evaluado/a en el Programa NutriCheck.\n\n📊 Estado: ${a.estado} · IMC: ${a.imc}${a.whtr?` · WHtR: ${a.whtr}`:""}\n\n${a.recomendacion}\n\nPuede acudir al Centro de Salud San Andrés para más información.\n\n— I.E. Cap. FAP Renán Elías Olivera · Programa NutriCheck`;
  $("repT").textContent=`Reporte: ${a.nombre}`;
  $("repS").textContent=`Para: ${a.apoderado}${a.telefono?" · +"+a.telefono:""}`;
  $("repBody").textContent=msg;
  $("mRep").dataset.msg=msg;
  openM("mRep");
}

async function sendRep(){
  if(!cur) return; const a=cur;
  let tel=(a.telefono||"").replace(/\D/g,"");
  if(tel.length===9) tel="51"+tel; if(!tel.startsWith("51")) tel="51"+tel;
  window.open(`https://api.whatsapp.com/send?phone=${tel}&text=${encodeURIComponent($("mRep").dataset.msg||"")}`, "_blank");
  closeM("mRep");
  try{ await fetch(SHEET_URL,{method:"POST",headers:{"Content-Type":"text/plain"},body:JSON.stringify({action:"guardarReporte",id_alumno:a.id,nombre:a.nombre,apoderado:a.apoderado,telefono:a.telefono,estado:a.estado,fecha:hoy(),usuario:user.email})}); }catch{}
  toast("Reporte enviado y registrado");
}

// ── DERIVAR / MEJORAR ─────────────────────────────────────
async function marcar(id){
  const a=DATA.find(x=>x.id===id); if(!a) return; spin("Actualizando Sheet…");
  try{
    const r=await fetch(SHEET_URL,{method:"POST",headers:{"Content-Type":"text/plain"},body:JSON.stringify({action:"marcarDerivado",id_alumno:id,fecha:hoy(),usuario:user.email})});
    const d=await r.json(); unspin();
    if(d.ok){ a.derivado=true; toast("Alumno marcado como derivado al CS ✓"); }
    else { toast("Error al marcar: "+(d.error||"desconocido")); return; }
  }catch(e){
    unspin();
    if(!isDemo){ toast("Error de red al marcar derivado"); return; }
    a.derivado=true; toast("Marcado localmente (demo)");
  }
  verDet(id); renderDash();
}

async function marcarMej(id){
  const a=DATA.find(x=>x.id===id); if(!a) return; spin("Actualizando Sheet…");
  try{
    const r=await fetch(SHEET_URL,{method:"POST",headers:{"Content-Type":"text/plain"},body:JSON.stringify({action:"marcarMejoro",id_alumno:id,usuario:user.email})});
    const d=await r.json(); unspin();
    if(d.ok){ a.mejoro=true; toast("Alumno marcado como recuperado ✓"); }
    else { toast("Error al marcar: "+(d.error||"desconocido")); return; }
  }catch(e){
    unspin();
    if(!isDemo){ toast("Error de red al marcar recuperado"); return; }
    a.mejoro=true; toast("Marcado localmente (demo)");
  }
  verDet(id); renderDash();
}

// ── NUEVO ALUMNO ──────────────────────────────────────────
function abrirNuevo(){
  ["nNom","nEdad","nPeso","nTalla","nCin","nApod","nTel","nRec"].forEach(i=>{$(i).value="";});
  $("nRec").dataset.auto="0";
  $("nuevoP").style.display="none"; openM("mNuevo");
}

function prevNuevo(){
  const p=parseFloat($("nPeso").value), t=parseFloat($("nTalla").value);
  const c=parseFloat($("nCin").value)||null, el=$("nuevoP");
  if(p>0&&t>0){
    const imc=calcIMC(p,t), est=calcEstado(imc), eb=eBase(est);
    const whtr=c?calcWHTR(c,t):null, col=EC(eb);
    const bg={Normal:"var(--green-50)","Bajo Peso":"var(--amber-50)",Sobrepeso:"var(--orange-100)",Obesidad:"var(--red-50)"}[eb]||"var(--bg)";
    $("nPrevV").textContent=imc; $("nPrevV").style.color=col;
    $("nPrevE").textContent=`Estado: ${est}`; $("nPrevE").style.color=col;
    $("nPrevW").textContent=whtr?`WHtR: ${whtr} · ${whtr>=0.5?"⚠ Riesgo abdominal":"Sin riesgo"}`:"";
    el.style.cssText=`display:block;background:${bg};border-color:${col}`;
    if(!$("nRec").value||$("nRec").dataset.auto==="1"){
      $("nRec").value=autoRec(est,$("nNom").value||"El alumno");
      $("nRec").dataset.auto="1";
    }
  } else el.style.display="none";
}

async function saveNuevo(){
  const nom=$("nNom").value.trim();
  const p=parseFloat($("nPeso").value), t=parseFloat($("nTalla").value);
  const c=parseFloat($("nCin").value)||null;
  if(!nom||!p||!t){ toast("Nombre, peso y talla son obligatorios"); return; }

  // Calcular en frontend
  const imc   = calcIMC(p,t);
  const whtr  = c?calcWHTR(c,t):null;
  const est   = calcEstado(imc);
  const rec   = $("nRec").value.trim()||autoRec(est,nom);
  const newId = Math.max(...DATA.map(a=>a.id),0)+1;

  // Deshabilitar botón para evitar doble submit
  const btn=$("btnSaveNuevo");
  btn.disabled=true; btn.textContent="Guardando…";

  spin("Registrando alumno en Google Sheet…");
  let savedOk=false;
  try{
    const r=await fetch(SHEET_URL,{
      method:"POST",
      headers:{"Content-Type":"text/plain"},
      body:JSON.stringify({
        action:"nuevoAlumno",
        id:newId, nombre:nom,
        grado:$("nGrado").value, seccion:$("nSec").value,
        edad:parseInt($("nEdad").value)||0, sexo:$("nSexo").value,
        peso:p, talla:t, cintura_cm:c,
        // imc/whtr/estado calculados en servidor automáticamente
        apoderado:$("nApod").value.trim(), telefono:$("nTel").value.trim(),
        recomendacion:rec, usuario:user.email
      })
    });
    const d=await r.json(); unspin();
    savedOk=d.ok;
    if(d.ok){
      toast(`Alumno registrado en Google Sheet (IMC: ${d.imc||imc} · ${d.estado||est})`);
    } else {
      toast("Error al guardar en Sheet: "+(d.error||"desconocido"));
    }
  }catch(err){
    unspin();
    toast(isDemo?"Alumno añadido al demo":"Error de red — alumno guardado localmente");
  }

  // Añadir a DATA local siempre
  DATA.push({
    id:newId, nombre:nom, grado:$("nGrado").value, seccion:$("nSec").value,
    edad:parseInt($("nEdad").value)||0, sexo:$("nSexo").value,
    peso:p, talla:t, imc, cintura_cm:c, whtr, estado:est, eb:eBase(est),
    derivado:false, mejoro:false, recomendacion:rec,
    apoderado:$("nApod").value.trim()||"No registrado",
    telefono:$("nTel").value.trim(),
    historial:[{fecha:hoy(),peso:p,talla:t,imc,estado:est}]
  });

  btn.disabled=false; btn.textContent="Registrar alumno";
  closeM("mNuevo"); renderDash(); renderList();
}

// ── CSV ───────────────────────────────────────────────────
function exportCSV(){
  const h="ID,Nombre,Grado,Sección,Edad,Sexo,Peso(kg),Talla(cm),IMC,Cintura(cm),WHtR,Estado,Derivado,Mejoró,Apoderado,Teléfono,Recomendación";
  const rows=DATA.map(a=>`${a.id},"${a.nombre}","${a.grado}",${a.seccion},${a.edad},${a.sexo},${a.peso},${a.talla},${a.imc},${a.cintura_cm||""},${a.whtr||""},"${a.estado}",${a.derivado?"SÍ":"NO"},${a.mejoro?"SÍ":"NO"},"${a.apoderado}",${a.telefono},"${(a.recomendacion||"").replace(/"/g,"'")}"`).join("\n");
  const blob=new Blob([h+"\n"+rows],{type:"text/csv;charset=utf-8;"}), url=URL.createObjectURL(blob), el=document.createElement("a");
  el.href=url; el.download=`nutricheck_${hoy()}.csv`; el.click();
  toast("CSV exportado correctamente");
}

