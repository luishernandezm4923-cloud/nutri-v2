  if(f){ modo=f.rol; user={email:f.e,rol:f.rol,nombre:f.nombre}; enterApp(modo==="salud"?"Personal de Salud":"UGEL Pisco"); }
  else{ err.textContent="Credenciales incorrectas. Verifique e intente de nuevo."; err.classList.add("on"); }
}

function enterApp(label){
  $("login").style.display="none";
  $("app").style.display="flex";
