          <div class="ref-row"><span class="badge bo">Bajo Peso Severo</span><span style="font-family:var(--mono);color:var(--t4);font-size:.76rem">IMC &lt; 14</span></div>
          <div class="ref-row"><span class="badge bb">Bajo Peso</span><span style="font-family:var(--mono);color:var(--t4);font-size:.76rem">IMC 14 – 18.4</span></div>
