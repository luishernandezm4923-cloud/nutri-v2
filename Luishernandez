          <div class="distrib-counts">
            <span class="distrib-num">${val}</span>
            <span class="distrib-pct">${pct(val,T)}%</span>
          </div>
        </div>
        <div class="distrib-track"><div class="distrib-fill" style="width:${pct(val,T)}%;background:${color}"></div></div>
      </div>`).join("");
  }
  if($("distribStacked")&&T>0){
    $("distribStacked").innerHTML=cats.map(([,val,color])=>`<div class="distrib-seg" style="flex:${val||0.01};background:${color}"></div>`).join("");
  }

  // Riesgo nivel
  let pT=0,pR=0,sT=0,sR=0;
  DATA.forEach(a=>{if(a.grado.includes("Primaria")){pT++;if(a.eb!=="Normal")pR++;}else{sT++;if(a.eb!=="Normal")sR++;}});
  const pp=pct(pR,pT),sp=pct(sR,sT);
  $("levelRisk").innerHTML=[[" Primaria",pp],["Secundaria",sp]].map(([l,v])=>`<div class="bar-row"><span class="bar-label">${l}</span><div class="bar-track"><div class="bar-fill ${v>=61?"rb-hi":v>=31?"rb-med":"rb-ok"}" style="width:${v}%;background:${v>=61?"var(--red-600)":v>=31?"var(--amber-500)":"var(--green-500)"}"></div></div><span class="bar-pct" style="color:${v>=61?"var(--red-600)":v>=31?"var(--amber-500)":"var(--green-500)"}">${v}%</span></div>`).join("");

  // Top grados
  const grps={};
  DATA.forEach(a=>{const k=`${a.grado}|${a.seccion}`;if(!grps[k])grps[k]={g:a.grado,s:a.seccion,t:0,r:0};grps[k].t++;if(a.eb!=="Normal")grps[k].r++;});
  allGrps=Object.values(grps).map(g=>({...g,p:pct(g.r,g.t)})).sort((a,b)=>b.p-a.p);
  const rnC=["background:var(--amber-100);color:var(--amber-700)","background:var(--slate-100);color:var(--slate-600)","background:var(--teal-50);color:var(--teal-700)","background:var(--slate-50);color:var(--slate-500)"];
  $("topRisk").innerHTML=allGrps.slice(0,4).map((g,i)=>`<div class="gt-row"><div class="gt-rank" style="${rnC[i]||rnC[3]}">${i+1}</div><div class="gt-name">${g.g} ${g.s}</div><div class="gt-pct" style="color:${g.p>=61?"var(--red-600)":g.p>=31?"var(--amber-500)":"var(--green-500)"}">${g.p}%</div></div>`).join("");

  // Trend chart IMC por fecha (usando historial)
  const allH=[];
  DATA.forEach(a=>(a.historial||[]).forEach(h=>allH.push({fecha:h.fecha,imc:h.imc})));
  allH.sort((a,b)=>a.fecha>b.fecha?1:-1);
  // agrupar por fecha
  const byFecha={};
  allH.forEach(h=>{if(!byFecha[h.fecha])byFecha[h.fecha]={sum:0,cnt:0};byFecha[h.fecha].sum+=h.imc;byFecha[h.fecha].cnt++;});
  const fechas=Object.keys(byFecha).slice(-8);
  const imcProms=fechas.map(f=>(byFecha[f].sum/byFecha[f].cnt).toFixed(1));
  if($("trendChart")){
    if(window._trendC) window._trendC.destroy();
    window._trendC=new Chart($("trendChart").getContext("2d"),{type:"line",data:{labels:fechas,datasets:[{label:"IMC Promedio",data:imcProms,borderColor:"#1e8080",backgroundColor:"rgba(30,128,128,.08)",tension:.4,fill:true,pointBackgroundColor:"#1e8080",pointRadius:3,pointHoverRadius:5,borderWidth:2}]},options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:false,grid:{color:"rgba(0,0,0,.04)"},ticks:{font:{size:10}}},x:{grid:{display:false},ticks:{font:{size:9},maxRotation:30}}}}});
  }

  // Recuperados
  const mej=DATA.filter(a=>a.mejoro);
  $("mejoraBox").innerHTML=mej.length?mej.map(a=>`<div class="rec-strip" onclick="verDet(${a.id})"><div class="av avn" style="width:34px;height:34px;font-size:.72rem">${ini(a.nombre)}</div><div><strong style="font-size:.8rem;font-family:var(--head)">${a.nombre}</strong><br><span style="font-size:.65rem;color:var(--t3);font-family:var(--mono)">${a.grado} · Recuperado ✓</span></div></div>`).join(""):`<div style="padding:10px 0;font-size:.75rem;color:var(--t4)">Sin mejoras registradas aún.</div>`;

  // Perfil stats
  $("pStats").innerHTML=[[`Monitoreados`,T],[`En riesgo`,T-N],[`Derivados`,derivados],[`Recuperados`,mejorados],[`IMC Prom.`,promIMC],[`WHtR ≥0.5`,whtrR]].map(([l,v])=>`<div class="stat-card"><div class="sv">${v}</div><div class="sl">${l}</div></div>`).join("");

  // Control: críticos pendientes
  if($("ctrlCriticos")){
    const criticos=DATA.filter(a=>(a.eb==="Obesidad"||(a.imc>0&&a.imc<14))&&!a.derivado).slice(0,4);
    $("ctrlCriticos").innerHTML=criticos.length?criticos.map(a=>`<div class="ctrl-item" onclick="verDet(${a.id})"><div class="av avo" style="width:34px;height:34px;font-size:.7rem;flex-shrink:0">${ini(a.nombre)}</div><div class="ctrl-body"><strong>${a.nombre}</strong><span>${a.grado} · IMC ${a.imc} · ${a.estado}</span></div><span class="ctrl-badge" style="background:var(--red-100);color:var(--red-800)">Urgente</span></div>`).join(""):`<div style="font-size:.75rem;color:var(--t4);padding:10px 0">Sin casos críticos pendientes de derivar.</div>`;
  }
}

