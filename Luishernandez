<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>NutriCheck Escolar · v5</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  /* Palette — Clinical Deep Teal + Warm Slate */
  --teal-900:#0a2e2e;--teal-800:#0f3d3d;--teal-700:#155555;
  --teal-600:#1a6b6b;--teal-500:#1e8080;--teal-400:#279494;
  --teal-300:#3db3b3;--teal-200:#7dd1d1;--teal-100:#c9ecec;--teal-50:#eaf7f7;

  --slate-900:#0f1923;--slate-800:#1a2635;--slate-700:#243347;
  --slate-600:#2f4259;--slate-500:#415a72;--slate-300:#8fa5bc;
  --slate-200:#bfcdd8;--slate-100:#dde5ec;--slate-50:#f0f4f7;--slate-10:#f7f9fb;

  --green-600:#166534;--green-500:#16a34a;--green-400:#22c55e;
  --green-100:#dcfce7;--green-50:#f0fdf4;
  --amber-700:#92400e;--amber-500:#d97706;--amber-100:#fef3c7;--amber-50:#fffbeb;
  --orange-700:#9a3412;--orange-500:#ea580c;--orange-100:#ffedd5;
  --red-800:#7f1d1d;--red-600:#dc2626;--red-100:#fee2e2;--red-50:#fef2f2;

  --bg:var(--slate-10);
  --card:#ffffff;
  --border:var(--slate-100);
  --border-md:var(--slate-200);

  --t1:var(--slate-900);--t2:var(--slate-700);--t3:var(--slate-500);--t4:var(--slate-300);

  --r-xl:20px;--r-lg:14px;--r-md:10px;--r-sm:7px;
  --sh-sm:0 1px 3px rgba(15,25,35,.06),0 2px 8px rgba(15,25,35,.04);
  --sh-md:0 4px 12px rgba(15,25,35,.07),0 1px 3px rgba(15,25,35,.05);
  --sh-lg:0 8px 24px rgba(15,25,35,.10),0 2px 6px rgba(15,25,35,.06);
  --sh-xl:0 20px 50px rgba(15,25,35,.18),0 4px 12px rgba(15,25,35,.08);

  --font:'DM Sans',sans-serif;
  --head:'Syne',sans-serif;
  --mono:'DM Mono',monospace;
  --ease:.18s cubic-bezier(.4,0,.2,1);

  --topbar-h:56px;--bnav-h:66px;
}

html,body{height:100%;-webkit-tap-highlight-color:transparent}
body{font-family:var(--font);background:var(--bg);color:var(--t1);overflow:hidden;font-size:15px;-webkit-font-smoothing:antialiased}

/* ── LOADER ─────────────────────────────────────── */
#loader{position:fixed;inset:0;background:var(--teal-900);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;z-index:9999;transition:opacity .5s,visibility .5s}
#loader.out{opacity:0;visibility:hidden}
.loader-mark{width:64px;height:64px;border-radius:18px;background:linear-gradient(135deg,var(--teal-400),var(--teal-200));display:flex;align-items:center;justify-content:center;animation:markPulse 2s ease-in-out infinite;box-shadow:0 0 0 0 rgba(61,179,179,.4)}
@keyframes markPulse{0%,100%{box-shadow:0 0 0 0 rgba(61,179,179,.4)}50%{box-shadow:0 0 0 18px rgba(61,179,179,0)}}
.loader-mark svg{width:32px;height:32px;stroke:#0a2e2e;fill:none;stroke-width:2.2}
.loader-wordmark{font-family:var(--head);font-size:1.1rem;font-weight:700;color:#fff;letter-spacing:.5px}
.loader-wordmark span{color:var(--teal-300)}
.loader-prog{width:160px;height:2px;background:rgba(255,255,255,.12);border-radius:2px;overflow:hidden}
.loader-prog-fill{height:100%;background:linear-gradient(90deg,var(--teal-400),var(--teal-200));animation:progAnim 1.4s ease-in-out infinite}
@keyframes progAnim{0%{width:0;margin-left:0}50%{width:100%;margin-left:0}100%{width:0;margin-left:100%}}
.loader-msg{font-size:.7rem;color:rgba(255,255,255,.4);font-family:var(--mono);letter-spacing:.5px}

/* ── SPINNER ─────────────────────────────────────── */
.spin-ov{position:fixed;inset:0;background:rgba(247,249,251,.9);backdrop-filter:blur(10px);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;z-index:8888;opacity:1;transition:opacity .2s}
.spin-ov.h{opacity:0;pointer-events:none}
.spin-ring{width:38px;height:38px;border:2.5px solid var(--border-md);border-top-color:var(--teal-500);border-radius:50%;animation:spinR .6s linear infinite}
@keyframes spinR{to{transform:rotate(360deg)}}
.spin-txt{font-size:.75rem;color:var(--t3);font-weight:500;font-family:var(--mono)}

/* ── TOAST ───────────────────────────────────────── */
.toast{position:fixed;bottom:calc(var(--bnav-h) + 12px);left:50%;transform:translateX(-50%) translateY(8px);background:var(--slate-800);color:#fff;padding:10px 20px;border-radius:50px;font-weight:500;font-size:.78rem;z-index:7777;opacity:0;transition:all .22s;white-space:nowrap;pointer-events:none;box-shadow:var(--sh-lg)}
.toast.on{opacity:1;transform:translateX(-50%) translateY(0)}

/* ── LOGIN ───────────────────────────────────────── */
#login{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;padding:1.5rem;background:linear-gradient(160deg,var(--teal-900) 0%,var(--slate-900) 55%,#041020 100%);overflow:hidden;z-index:100}
.lg-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(61,179,179,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(61,179,179,.04) 1px,transparent 1px);background-size:40px 40px;pointer-events:none}
.lg-glow{position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(30,128,128,.12) 0%,transparent 70%);top:-100px;left:-100px;pointer-events:none}
.lg-glow2{position:absolute;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(30,128,128,.08) 0%,transparent 70%);bottom:-80px;right:-80px;pointer-events:none}
.login-card{background:rgba(255,255,255,.97);border-radius:24px;padding:2.4rem 2rem 2rem;max-width:400px;width:100%;box-shadow:var(--sh-xl);position:relative;z-index:1;animation:lgUp .5s cubic-bezier(.34,1.46,.64,1)}
@keyframes lgUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.brand{display:flex;align-items:center;gap:13px;margin-bottom:4px}
.brand-mark{width:48px;height:48px;border-radius:13px;background:linear-gradient(135deg,var(--teal-700),var(--teal-400));display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 6px 18px rgba(21,85,85,.35)}
.brand-mark svg{width:24px;height:24px;stroke:#fff;fill:none;stroke-width:2}
.brand-name{font-family:var(--head);font-size:1.2rem;font-weight:800;color:var(--slate-900);line-height:1.1}
.brand-sub{font-size:.65rem;color:var(--t3);display:block;margin-top:2px}
.ver-pill{display:inline-flex;align-items:center;gap:5px;background:var(--teal-50);color:var(--teal-700);font-size:.6rem;font-weight:700;padding:3px 8px;border-radius:20px;font-family:var(--mono);margin:10px 0 18px;border:1px solid var(--teal-100)}
.ver-dot{width:5px;height:5px;border-radius:50%;background:var(--teal-400);animation:verPulse 2s ease infinite}
@keyframes verPulse{0%,100%{opacity:1}50%{opacity:.4}}
.divider{height:1px;background:var(--border);margin-bottom:20px}
.fl{font-size:.64rem;font-weight:700;text-transform:uppercase;letter-spacing:.9px;color:var(--t4);margin-bottom:5px;display:block}
.fi{display:flex;align-items:center;gap:9px;border:1.5px solid var(--border);border-radius:var(--r-md);padding:10px 12px;margin-bottom:10px;transition:border-color var(--ease),box-shadow var(--ease)}
.fi:focus-within{border-color:var(--teal-400);box-shadow:0 0 0 3px rgba(61,179,179,.14)}
.fi svg{flex-shrink:0;color:var(--t4);width:15px;height:15px;stroke:currentColor;fill:none}
.fi input{flex:1;border:none;outline:none;font-family:var(--font);font-size:.86rem;color:var(--t1);background:transparent}
.btn-primary{border:none;border-radius:var(--r-md);padding:13px;font-weight:700;font-size:.88rem;font-family:var(--head);width:100%;cursor:pointer;background:linear-gradient(135deg,var(--teal-700),var(--teal-400));color:#fff;letter-spacing:.3px;transition:all var(--ease);position:relative;overflow:hidden}
.btn-primary::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,transparent,rgba(255,255,255,.1));opacity:0;transition:opacity var(--ease)}
.btn-primary:hover::after{opacity:1}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(21,85,85,.4)}
.btn-primary:active{transform:translateY(0)}
.l-err{background:var(--red-50);color:#991b1b;border:1px solid #fecaca;border-radius:var(--r-sm);padding:9px 12px;font-size:.76rem;font-weight:500;margin-bottom:10px;display:none;animation:shake .3s}
.l-err.on{display:block}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-4px)}75%{transform:translateX(4px)}}
.qa-label{font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--t4);margin:18px 0 10px}
.qbtn{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:var(--r-md);cursor:pointer;border:1.5px solid var(--border);margin-bottom:6px;transition:all var(--ease);background:#fff}
.qbtn:hover{background:var(--bg);border-color:var(--teal-200)}
.qd{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.qi strong{font-size:.76rem;color:var(--t1);display:block;font-weight:600}
.qi small{font-size:.64rem;color:var(--t3);font-family:var(--mono)}

/* ── APP SHELL ───────────────────────────────────── */
#app{display:none;height:100vh;flex-direction:column}

/* topbar */
.tb{background:#fff;height:var(--topbar-h);display:flex;align-items:center;justify-content:space-between;padding:0 16px;border-bottom:1px solid var(--border);flex-shrink:0;box-shadow:var(--sh-sm)}
.tb-left{display:flex;align-items:center;gap:9px}
.tb-mark{width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,var(--teal-700),var(--teal-400));display:flex;align-items:center;justify-content:center}
.tb-mark svg{width:14px;height:14px;stroke:#fff;fill:none;stroke-width:2.2}
.tb-name{font-family:var(--head);font-weight:800;font-size:.95rem;color:var(--slate-900)}
.tb-right{display:flex;align-items:center;gap:6px}
.uchip{background:var(--teal-50);color:var(--teal-700);border-radius:20px;padding:4px 11px;font-size:.7rem;font-weight:600;border:1px solid var(--teal-100);max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ico-btn{background:none;border:none;cursor:pointer;padding:7px;border-radius:8px;display:flex;align-items:center;color:var(--t3);transition:all var(--ease)}
.ico-btn:hover{background:var(--bg);color:var(--t2)}
.ico-btn svg{width:17px;height:17px;stroke:currentColor;fill:none}

.demo-banner{background:linear-gradient(90deg,var(--amber-50),#fffdf5);border-bottom:1px solid var(--amber-100);padding:6px 16px;font-size:.7rem;font-weight:600;color:var(--amber-700);display:none;text-align:center}
.demo-banner.on{display:block}

/* content + nav */
.content{flex:1;overflow-y:auto;padding-bottom:calc(var(--bnav-h) + 4px);-webkit-overflow-scrolling:touch}
.bnav{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid var(--border);display:flex;padding:6px 8px env(safe-area-inset-bottom,8px);z-index:20;box-shadow:0 -2px 16px rgba(15,25,35,.06)}
.nbt{flex:1;background:none;border:none;display:flex;flex-direction:column;align-items:center;gap:2px;font-size:.6rem;font-weight:700;color:var(--t4);padding:7px 4px;border-radius:var(--r-md);cursor:pointer;transition:all var(--ease);font-family:var(--head);letter-spacing:.3px;text-transform:uppercase}
.nbt svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:1.8;transition:all var(--ease)}
.nbt.on{color:var(--teal-600)}
.nbt.on svg{stroke:var(--teal-600)}

/* pages */
.page{display:none}
.page.ap{display:block;animation:pgIn .2s ease}
@keyframes pgIn{from{opacity:0;transform:translateY(3px)}to{opacity:1;transform:translateY(0)}}

/* ── SHARED COMPONENTS ───────────────────────────── */
.card{background:var(--card);border-radius:var(--r-lg);padding:16px;margin:10px 12px;box-shadow:var(--sh-sm);border:1px solid var(--border)}
.card-hd{font-family:var(--head);font-size:.82rem;font-weight:700;color:var(--t2);margin-bottom:14px;display:flex;align-items:center;gap:7px;text-transform:uppercase;letter-spacing:.6px}
.card-hd-dot{width:7px;height:7px;border-radius:50%;background:var(--teal-400);flex-shrink:0}
.ph{padding:14px 14px 6px}
.ph-eyebrow{font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--teal-500);margin-bottom:4px;font-family:var(--mono)}
.ph h2{font-family:var(--head);font-size:1.4rem;font-weight:800;color:var(--t1);line-height:1.1}
.ph p{font-size:.74rem;color:var(--t3);margin-top:4px}

/* badges */
.badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:20px;font-size:.62rem;font-weight:700;letter-spacing:.1px;font-family:var(--mono)}
.bn{background:var(--green-100);color:var(--green-600)}
.bb{background:var(--amber-100);color:var(--amber-700)}
.bs{background:var(--orange-100);color:var(--orange-700)}
.bo{background:var(--red-100);color:var(--red-800)}

/* avatars */
.av{border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;color:#fff;flex-shrink:0;font-size:.78rem;font-family:var(--head)}
.avn{background:linear-gradient(135deg,var(--green-600),var(--green-400))}
.avb{background:linear-gradient(135deg,var(--amber-700),var(--amber-500))}
.avs{background:linear-gradient(135deg,var(--orange-700),var(--orange-500))}
.avo{background:linear-gradient(135deg,var(--red-800),var(--red-600))}

/* ── SIDEBAR DESKTOP / TAB NAV ───────────────────── */
.bnav{position:fixed;bottom:0;left:0;right:0;background:var(--slate-900);border-top:1px solid rgba(255,255,255,.06);display:flex;padding:0 4px env(safe-area-inset-bottom,4px);z-index:20;box-shadow:0 -2px 20px rgba(0,0,0,.25)}
.nbt{flex:1;background:none;border:none;display:flex;flex-direction:column;align-items:center;gap:2px;font-size:.52rem;font-weight:700;color:rgba(255,255,255,.35);padding:8px 4px 6px;border-radius:0;cursor:pointer;transition:all .15s;font-family:var(--head);letter-spacing:.5px;text-transform:uppercase;position:relative}
.nbt svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.8;transition:all .15s}
.nbt.on{color:var(--teal-300)}
.nbt.on svg{stroke:var(--teal-300)}
.nbt.on::after{content:'';position:absolute;top:0;left:20%;right:20%;height:2px;background:var(--teal-400);border-radius:0 0 2px 2px}

/* ── EXEC DASHBOARD GRID ─────────────────────────── */
.exec-header{padding:16px 16px 0;background:linear-gradient(135deg,var(--slate-900) 0%,var(--teal-900) 100%);margin:-0px;color:#fff}
.exec-eyebrow{font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--teal-300);font-family:var(--mono);margin-bottom:2px}
.exec-title{font-family:var(--head);font-size:1.4rem;font-weight:800;color:#fff;line-height:1.1}
.exec-sub{font-size:.68rem;color:rgba(255,255,255,.4);margin-top:3px;font-family:var(--mono)}
.exec-date{font-size:.62rem;color:var(--teal-300);font-family:var(--mono);margin-top:6px;padding-bottom:14px}

/* KPI row top */
.kpi-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:12px 12px 0}
.kpi-card{border-radius:12px;padding:14px 14px 12px;position:relative;overflow:hidden;cursor:pointer;transition:transform .15s}
.kpi-card:active{transform:scale(.97)}
.kpi-card .kc-label{font-size:.57rem;font-weight:700;text-transform:uppercase;letter-spacing:.8px;opacity:.7;font-family:var(--mono);margin-bottom:4px}
.kpi-card .kc-val{font-family:var(--head);font-size:2rem;font-weight:800;line-height:1;letter-spacing:-1px}
.kpi-card .kc-sub{font-size:.62rem;opacity:.65;margin-top:4px;font-family:var(--mono)}
.kpi-card .kc-arrow{position:absolute;top:12px;right:12px;font-size:.7rem;opacity:.5}
.kpi-card .kc-icon{position:absolute;bottom:-6px;right:-4px;opacity:.07}
.kpi-card .kc-icon svg{width:56px;height:56px;stroke:currentColor;fill:none;stroke-width:1}
.kc-dark{background:var(--slate-800);color:#fff;border:1px solid rgba(255,255,255,.06)}
.kc-teal{background:linear-gradient(135deg,#0d5c5c,#1e8080);color:#fff}
.kc-amber{background:linear-gradient(135deg,#78340e,#c2680a);color:#fff}
.kc-red{background:linear-gradient(135deg,#6b1a1a,#c52626);color:#fff;grid-column:span 2}
.kc-green{background:linear-gradient(135deg,#14532d,#16a34a);color:#fff}
.kc-red .kc-val{font-size:2.6rem}

/* Metric row */
.metric-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;padding:8px 12px 0}
.metric-box{background:#fff;border-radius:10px;padding:11px 10px;text-align:center;border:1px solid var(--border);box-shadow:var(--sh-sm)}
.metric-box .mb-val{font-family:var(--mono);font-size:1.1rem;font-weight:700;color:var(--t1)}
.metric-box .mb-lbl{font-size:.55rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--t4);margin-top:2px}

/* Chart section */
.chart-section{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:8px 12px 0}
.chart-panel{background:#fff;border-radius:12px;padding:13px;border:1px solid var(--border);box-shadow:var(--sh-sm)}
.chart-panel.full{grid-column:span 2}
.cp-title{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--t3);margin-bottom:10px;font-family:var(--mono);display:flex;align-items:center;gap:5px}
.cp-title::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--teal-400);flex-shrink:0}

/* Pipeline / Bar Chart */
.bar-row{display:flex;align-items:center;gap:7px;margin-bottom:8px;font-size:.72rem}
.bar-row:last-child{margin-bottom:0}
.bar-label{width:70px;color:var(--t3);flex-shrink:0;font-size:.66rem}
.bar-track{flex:1;height:7px;background:var(--slate-100);border-radius:4px;overflow:hidden}
.bar-fill{height:100%;border-radius:4px;transition:width .8s cubic-bezier(.4,0,.2,1)}
.bar-pct{width:30px;text-align:right;font-family:var(--mono);font-weight:700;font-size:.68rem}

/* Distribución stacked bars */
.distrib-wrap{display:flex;flex-direction:column;gap:7px}
.distrib-row{display:flex;flex-direction:column;gap:3px}
.distrib-head{display:flex;justify-content:space-between;align-items:center}
.distrib-label{font-size:.66rem;font-weight:700;color:var(--t2);font-family:var(--head)}
.distrib-counts{display:flex;gap:5px;align-items:center}
.distrib-num{font-family:var(--mono);font-size:.7rem;font-weight:700;color:var(--t1)}
.distrib-pct{font-family:var(--mono);font-size:.6rem;color:var(--t4)}
.distrib-track{height:8px;background:var(--slate-100);border-radius:5px;overflow:hidden}
.distrib-fill{height:100%;border-radius:5px;transition:width .9s cubic-bezier(.4,0,.2,1)}
.distrib-stacked{height:12px;border-radius:6px;overflow:hidden;display:flex;margin-top:4px;gap:1px}
.distrib-seg{height:100%;transition:flex .9s cubic-bezier(.4,0,.2,1);border-radius:0}
.distrib-seg:first-child{border-radius:6px 0 0 6px}
.distrib-seg:last-child{border-radius:0 6px 6px 0}

/* Grade risk table */
.grade-table{width:100%}
.gt-row{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--border);font-size:.72rem}
.gt-row:last-child{border:none}
.gt-rank{width:20px;height:20px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:.62rem;font-weight:800;font-family:var(--head);flex-shrink:0}
.gt-name{flex:1;color:var(--t2);font-weight:600}
.gt-pct{font-family:var(--mono);font-weight:800;font-size:.74rem}

/* Trend line */
.trend-mini{height:50px;width:100%;margin-top:6px}

/* Alert strip */
.alert-strip{padding:0 12px;margin-top:8px}
.astrip{display:flex;align-items:center;gap:10px;background:var(--red-50);border:1px solid #fecaca;border-radius:10px;padding:10px 12px;margin-bottom:6px;cursor:pointer}
.astrip.amb{background:var(--amber-50);border-color:var(--amber-100)}
.astrip.teal{background:var(--teal-50);border-color:var(--teal-100)}
.astrip-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;background:var(--red-600)}
.astrip.amb .astrip-dot{background:var(--amber-500)}
.astrip.teal .astrip-dot{background:var(--teal-400)}
.astrip-body{flex:1}
.astrip-body b{font-size:.74rem;display:block;color:var(--t1)}
.astrip-body span{font-size:.65rem;color:var(--t3)}
.astrip-arrow{color:var(--t4);font-size:.8rem}

/* Recovered row */
.rec-strip{display:flex;align-items:center;gap:9px;padding:8px 0;border-bottom:1px solid var(--border);cursor:pointer}
.rec-strip:last-child{border:none}

/* Calculadora panel */
.calc-panel{background:linear-gradient(135deg,var(--slate-900),var(--teal-900));border-radius:12px;padding:14px;margin:8px 12px 0;color:#fff;border:1px solid rgba(255,255,255,.06)}
.calc-panel-title{font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:.9px;color:rgba(255,255,255,.4);font-family:var(--mono);margin-bottom:10px;display:flex;align-items:center;gap:6px}
.calc-panel-title::after{content:'';flex:1;height:1px;background:rgba(255,255,255,.07)}
.calc-inputs{display:flex;gap:7px;margin-bottom:9px}
.calc-inp{flex:1;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:7px;padding:8px 9px;font-family:var(--mono);font-size:.82rem;color:#fff;outline:none;width:100%}
.calc-inp::placeholder{color:rgba(255,255,255,.25)}
.calc-inp:focus{border-color:var(--teal-400);background:rgba(255,255,255,.1)}
.calc-output{background:rgba(255,255,255,.05);border-radius:8px;padding:10px;text-align:center;font-size:.72rem;color:rgba(255,255,255,.5);font-family:var(--mono);min-height:38px;display:flex;align-items:center;justify-content:center}

/* Panel header con botones */
.panel-actions{display:flex;gap:6px;padding:10px 12px 0;flex-wrap:wrap}
.pact-btn{display:flex;align-items:center;gap:5px;padding:7px 11px;border-radius:8px;font-size:.68rem;font-weight:700;cursor:pointer;border:1.5px solid var(--border);background:#fff;color:var(--t2);font-family:var(--head);transition:all .15s}
.pact-btn:hover{background:var(--bg);border-color:var(--teal-200);color:var(--teal-700)}
.pact-btn.primary{background:var(--teal-700);color:#fff;border-color:var(--teal-700)}
.pact-btn.primary:hover{background:var(--teal-600)}

/* IMC trend sparkline */
.spark-row{display:flex;align-items:flex-end;gap:2px;height:40px;margin-top:8px}
.spark-bar{flex:1;border-radius:2px 2px 0 0;transition:height .5s;min-height:3px;cursor:pointer}

/* Summary strip */
.summ-strip{background:linear-gradient(90deg,var(--teal-50),#fff);border:1px solid var(--teal-100);border-radius:10px;padding:10px 12px;margin:8px 12px 0;display:flex;gap:14px}
.summ-item{flex:1;text-align:center}
.summ-val{font-family:var(--head);font-size:1.2rem;font-weight:800;color:var(--teal-700)}
.summ-lbl{font-size:.55rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--t4);margin-top:1px}

/* Tab indicator */
.tab-panel{display:none;flex-direction:column}
.tab-panel.active{display:flex}

/* ── PANEL CONTROL (tab 2) ───────────────────────── */
.ctrl-section{padding:12px 12px 0}
.ctrl-section-title{font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.9px;color:var(--t4);font-family:var(--mono);margin-bottom:10px;display:flex;align-items:center;gap:6px}
.ctrl-section-title::after{content:'';flex:1;height:1px;background:var(--border)}
.ctrl-list{display:flex;flex-direction:column;gap:7px;margin-bottom:12px}
.ctrl-item{display:flex;align-items:center;gap:11px;background:#fff;border-radius:10px;padding:11px 12px;border:1px solid var(--border);box-shadow:var(--sh-sm);cursor:pointer;transition:all .15s}
.ctrl-item:hover{border-color:var(--teal-200);box-shadow:var(--sh-md)}
.ctrl-icon{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ctrl-icon svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2}
.ctrl-body{flex:1}
.ctrl-body strong{font-size:.8rem;font-weight:700;font-family:var(--head);color:var(--t1);display:block}
.ctrl-body span{font-size:.65rem;color:var(--t3)}
.ctrl-badge{font-family:var(--mono);font-size:.68rem;font-weight:700;padding:3px 8px;border-radius:20px}

/* IMC reference card */
.ref-card{background:#fff;border-radius:12px;margin:0 12px;padding:13px;border:1px solid var(--border);box-shadow:var(--sh-sm)}
.ref-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:.78rem}
.ref-row:last-child{border:none}

/* Perfil mejorado */
.perfil-hero{background:linear-gradient(135deg,var(--teal-900),var(--slate-800));margin:0;padding:24px 20px;text-align:center;color:#fff}
.perfil-avatar{width:60px;height:60px;border-radius:16px;background:linear-gradient(135deg,var(--teal-400),var(--teal-200));display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin:0 auto 12px;box-shadow:0 8px 22px rgba(21,85,85,.4)}
.perfil-name{font-family:var(--head);font-size:1.1rem;font-weight:800}
.perfil-email{font-size:.68rem;color:rgba(255,255,255,.5);font-family:var(--mono);margin-top:3px}
.perfil-role{display:inline-flex;align-items:center;gap:4px;background:rgba(61,179,179,.2);color:var(--teal-200);border-radius:20px;padding:3px 10px;font-size:.62rem;font-weight:700;font-family:var(--mono);margin-top:8px;border:1px solid rgba(61,179,179,.3)}
.stat-cards{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:12px}
.stat-card{background:#fff;border-radius:10px;padding:13px;border:1px solid var(--border);box-shadow:var(--sh-sm);text-align:center}
.stat-card .sv{font-family:var(--mono);font-size:1.3rem;font-weight:700;color:var(--teal-700)}
.stat-card .sl{font-size:.58rem;text-transform:uppercase;letter-spacing:.5px;color:var(--t4);font-weight:700;margin-top:2px}
.calc-field label{font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.6px;opacity:.45;display:block;margin-bottom:4px;font-family:var(--mono)}
.calc-input{width:100%;padding:9px 10px;border:1px solid rgba(255,255,255,.12);border-radius:var(--r-sm);font-family:var(--mono);font-size:.88rem;background:rgba(255,255,255,.07);color:#fff;outline:none;transition:border-color var(--ease)}
.calc-input::placeholder{opacity:.3;font-size:.8rem}
.calc-input:focus{border-color:rgba(61,179,179,.5);background:rgba(255,255,255,.1)}
.calc-result{background:rgba(255,255,255,.06);border-radius:var(--r-md);padding:12px 14px;display:flex;align-items:center;justify-content:space-between;border:1px solid rgba(255,255,255,.07)}
.calc-imc-val{font-family:var(--head);font-size:2rem;font-weight:800;line-height:1;letter-spacing:-1px}
.calc-status{font-size:.74rem;font-weight:700;margin-top:2px;opacity:.85}
.calc-whtr{font-size:.66rem;opacity:.5;font-family:var(--mono);margin-top:3px}
.calc-placeholder{font-size:.74rem;opacity:.35;text-align:center;width:100%;font-family:var(--mono)}

/* ── ALUMNOS ─────────────────────────────────────── */
.fbar{background:#fff;border-bottom:1px solid var(--border);padding:10px 12px;display:flex;flex-wrap:wrap;gap:8px;align-items:flex-end}
.fg label{font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--t4);display:block;margin-bottom:4px}
.fsel{padding:7px 10px;border-radius:var(--r-sm);border:1.5px solid var(--border);font-family:var(--font);font-size:.76rem;color:var(--t1);background:#fff;transition:border-color var(--ease);min-width:110px}
.fsel:focus{outline:none;border-color:var(--teal-400)}
.mini-btn{background:#fff;border:1.5px solid var(--border);border-radius:var(--r-sm);padding:6px 12px;font-size:.72rem;font-weight:600;cursor:pointer;font-family:var(--font);color:var(--t2);transition:all var(--ease);display:inline-flex;align-items:center;gap:5px}
.mini-btn:hover{background:var(--bg);border-color:var(--border-md)}
.search-wrap{padding:10px 12px 6px}
.search-bar{background:#fff;border-radius:30px;padding:9px 15px;display:flex;gap:8px;align-items:center;border:1.5px solid var(--border);box-shadow:var(--sh-sm);transition:all var(--ease)}
.search-bar:focus-within{border-color:var(--teal-400);box-shadow:0 0 0 3px rgba(61,179,179,.1)}
.search-bar input{flex:1;border:none;outline:none;font-family:var(--font);font-size:.83rem;background:transparent;color:var(--t1)}
.chips{display:flex;gap:6px;padding:0 12px 8px;overflow-x:auto;scrollbar-width:none}
.chips::-webkit-scrollbar{display:none}
.chip{padding:5px 12px;border-radius:20px;font-size:.66rem;font-weight:700;background:#fff;border:1.5px solid var(--border);white-space:nowrap;cursor:pointer;transition:all var(--ease);color:var(--t3);font-family:var(--mono)}
.chip.on{background:var(--teal-700);color:#fff;border-color:var(--teal-700)}
.list-count{padding:0 13px 5px;font-size:.7rem;color:var(--t4);font-weight:500;font-family:var(--mono)}
.list-wrap{padding:0 12px 8px}

/* alumno item */
.al{background:#fff;border-radius:var(--r-lg);padding:12px 13px;margin-bottom:7px;display:flex;align-items:center;gap:11px;cursor:pointer;box-shadow:var(--sh-sm);transition:all var(--ease);border:1px solid var(--border);border-left:3px solid transparent}
.al:hover{transform:translateY(-1px);box-shadow:var(--sh-md)}
.al:active{transform:translateY(0)}
.al.bl-n{border-left-color:var(--green-500)}
.al.bl-b{border-left-color:var(--amber-500)}
.al.bl-s{border-left-color:var(--orange-500)}
.al.bl-o{border-left-color:var(--red-600)}
.al.crit{background:#fff9f9}
.al-info{flex:1;min-width:0}
.al-name{font-weight:700;font-size:.85rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--t1);font-family:var(--head)}
.al-sub{font-size:.69rem;color:var(--t3);margin-top:3px;display:flex;align-items:center;flex-wrap:wrap;gap:4px}
.al-contact{font-size:.65rem;color:var(--t4);margin-top:3px}
.al-stats{flex-shrink:0;text-align:right}
.al-imc{font-family:var(--mono);font-size:.8rem;font-weight:600;line-height:1.4}
.al-whtr{font-family:var(--mono);font-size:.62rem;color:var(--t4)}

/* ── DETALLE ─────────────────────────────────────── */
.backbar{background:#fff;padding:13px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:9px;cursor:pointer;transition:background var(--ease)}
.backbar:hover{background:var(--bg)}
.backbar svg{width:18px;height:18px;stroke:var(--t3);fill:none}
.backbar span{font-size:.84rem;font-weight:600;color:var(--t2)}

.det-hero{background:linear-gradient(150deg,var(--teal-800),var(--teal-600));margin:10px 12px;border-radius:var(--r-lg);padding:20px 16px;color:#fff;box-shadow:var(--sh-lg);position:relative;overflow:hidden;border:1px solid var(--teal-700)}
.det-hero::after{content:'';position:absolute;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.04);top:-80px;right:-60px}
.det-av{width:54px;height:54px;border-radius:14px;background:rgba(255,255,255,.12);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;font-size:1.2rem;font-weight:800;margin-bottom:12px;border:1px solid rgba(255,255,255,.2);font-family:var(--head)}
.det-name{font-family:var(--head);font-size:1.1rem;font-weight:800;margin-bottom:3px}
.det-meta{font-size:.72rem;opacity:.6;margin-bottom:12px;font-family:var(--mono)}
.det-chips{display:flex;gap:6px;flex-wrap:wrap}
.det-chip{background:rgba(255,255,255,.1);backdrop-filter:blur(4px);border:1px solid rgba(255,255,255,.15);border-radius:20px;padding:3px 10px;font-size:.65rem;font-weight:700;font-family:var(--mono)}
.det-chip.urg{background:rgba(220,38,38,.25);border-color:rgba(220,38,38,.4)}
.det-chip.ok{background:rgba(22,163,74,.25);border-color:rgba(22,163,74,.4)}

.stat-grid{display:flex;gap:8px;flex-wrap:wrap}
.sbox{flex:1;min-width:65px;background:var(--bg);border-radius:var(--r-md);padding:11px;text-align:center;border:1px solid var(--border)}
.sv{font-family:var(--mono);font-size:1.15rem;font-weight:600;line-height:1}
.sl{font-size:.57rem;color:var(--t4);font-weight:700;margin-top:3px;text-transform:uppercase;letter-spacing:.5px}

/* OMS scale */
.oms-scale{position:relative;height:10px;border-radius:6px;overflow:visible;margin:12px 0 8px;background:linear-gradient(to right,#1a6b6b 0%,#1a6b6b 25%,#d97706 25%,#d97706 50%,#ea580c 50%,#ea580c 72%,#dc2626 72%,#dc2626 100%)}
.oms-needle{position:absolute;top:-5px;width:20px;height:20px;border-radius:50%;background:#fff;border:2.5px solid var(--slate-900);transform:translateX(-50%);box-shadow:0 2px 8px rgba(0,0,0,.2);transition:left .7s cubic-bezier(.34,1.1,.64,1)}
.oms-ticks{display:flex;justify-content:space-between;font-size:.56rem;color:var(--t4);font-family:var(--mono)}
.oms-legend{display:flex;gap:3px;margin-top:8px;font-size:.58rem}
.oms-seg{flex:1;text-align:center;padding:3px 1px;border-radius:4px;font-weight:700;font-family:var(--mono)}
.oms-seg.s0{background:var(--teal-50);color:var(--teal-700)}
.oms-seg.s1{background:var(--green-100);color:var(--green-600)}
.oms-seg.s2{background:var(--amber-100);color:var(--amber-700)}
.oms-seg.s3{background:var(--orange-100);color:var(--orange-700)}
.oms-seg.s4{background:var(--red-100);color:var(--red-800)}

.whtr-scale{height:8px;border-radius:5px;background:linear-gradient(to right,var(--teal-500) 0%,var(--teal-500) 50%,var(--red-600) 50%,var(--red-600) 100%);margin:10px 0 5px;position:relative;overflow:visible}
.whtr-needle{position:absolute;top:-4px;width:16px;height:16px;border-radius:50%;background:#fff;border:2.5px solid var(--slate-800);transform:translateX(-50%);box-shadow:0 2px 6px rgba(0,0,0,.15);transition:left .6s cubic-bezier(.34,1.1,.64,1)}

.rec{background:var(--teal-50);border-left:3px solid var(--teal-400);border-radius:var(--r-md);padding:13px;font-size:.81rem;line-height:1.7;color:var(--t2)}
.rec.urgent{background:var(--red-50);border-left-color:var(--red-600)}

.hist-item{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--border);font-size:.77rem;gap:8px}
.hist-item:last-child{border-bottom:none}
.hist-date{font-family:var(--mono);font-size:.66rem;color:var(--t4);flex-shrink:0}
.hist-vals{color:var(--t3);font-size:.72rem}
.hist-imc{font-family:var(--mono);font-weight:600}

/* contact */
.phone-pill{background:var(--teal-50);border:1.5px solid var(--teal-100);border-radius:20px;padding:7px 14px;font-weight:700;font-size:.76rem;color:var(--teal-700);font-family:var(--mono);cursor:pointer;transition:all var(--ease);display:inline-block}
.phone-pill:hover{background:var(--teal-700);color:#fff;border-color:var(--teal-700)}

/* actions */
.acts{padding:10px 12px;display:flex;flex-direction:column;gap:8px;margin-bottom:80px}
.btn-act{border:none;border-radius:var(--r-md);padding:13px;font-size:.83rem;font-weight:700;cursor:pointer;font-family:var(--head);transition:all var(--ease);width:100%;display:flex;align-items:center;justify-content:center;gap:7px;letter-spacing:.1px}
.btn-outline{background:#fff;border:1.5px solid var(--border-md);color:var(--t2)}
.btn-outline:hover{background:var(--bg)}
.btn-green{background:linear-gradient(135deg,var(--green-600),var(--green-400));color:#fff;box-shadow:0 3px 10px rgba(22,163,74,.25)}
.btn-green:hover{filter:brightness(1.06)}
.btn-red{background:linear-gradient(135deg,var(--red-800),var(--red-600));color:#fff;box-shadow:0 3px 10px rgba(220,38,38,.25)}
.btn-red:hover{filter:brightness(1.06)}
.btn-done{background:var(--green-100);color:var(--green-600);cursor:default;border:1px solid #bbf7d0}
.btn-warn{background:linear-gradient(135deg,var(--amber-700),var(--amber-500));color:#fff}
.btn-green{background:linear-gradient(135deg,var(--green-600),var(--green-400));color:#fff;box-shadow:0 3px 10px rgba(22,163,74,.25)}
.btn-green:hover{filter:brightness(1.06)}
.btn-teal{background:linear-gradient(135deg,var(--teal-700),var(--teal-500));color:#fff;box-shadow:0 3px 10px rgba(26,107,107,.25)}
.btn-teal:hover{filter:brightness(1.06)}

/* ── MODAL ───────────────────────────────────────── */
.modal{position:fixed;inset:0;background:rgba(10,22,30,.6);backdrop-filter:blur(10px);display:flex;align-items:flex-end;justify-content:center;z-index:500;visibility:hidden;opacity:0;transition:all .22s}
.modal.on{visibility:visible;opacity:1}
.msheet{background:#fff;width:100%;max-width:520px;border-radius:22px 22px 0 0;padding:20px;max-height:93vh;overflow-y:auto;transform:translateY(24px);transition:transform .25s;-webkit-overflow-scrolling:touch}
.modal.on .msheet{transform:translateY(0)}
.mhandle{width:32px;height:3px;background:var(--border-md);border-radius:2px;margin:0 auto 20px}
.mt{font-family:var(--head);font-size:1.05rem;font-weight:800;color:var(--t1)}
.ms{font-size:.75rem;color:var(--t4);margin-top:3px;margin-bottom:16px;font-family:var(--mono)}
.mf{margin-bottom:11px}
.mf label{font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--t4);display:block;margin-bottom:4px;font-family:var(--mono)}
.mi{width:100%;padding:10px 12px;border:1.5px solid var(--border);border-radius:var(--r-sm);font-family:var(--font);font-size:.85rem;outline:none;transition:border-color var(--ease),box-shadow var(--ease);color:var(--t1)}
.mi:focus{border-color:var(--teal-400);box-shadow:0 0 0 3px rgba(61,179,179,.1)}
.mrow{display:flex;gap:9px}
.mrow .mf{flex:1}
.msec{font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--teal-600);background:var(--teal-50);border-radius:5px;padding:5px 10px;margin:8px 0 11px;border:1px solid var(--teal-100)}
.mbtn-row{display:flex;gap:8px;margin-top:8px}
.mbtn-row .btn-act{flex:1}

/* imc preview */
.imc-prev{border-radius:var(--r-md);padding:13px;text-align:center;display:none;border:1.5px solid;margin-bottom:11px;animation:fadeIn .2s}
@keyframes fadeIn{from{opacity:0;transform:scale(.97)}to{opacity:1;transform:scale(1)}}
.imc-val{font-family:var(--head);font-size:1.9rem;font-weight:800;line-height:1;letter-spacing:-1px}
.imc-est{font-size:.78rem;font-weight:700;margin-top:3px}
.imc-whtr{font-size:.68rem;color:var(--t3);margin-top:3px;font-family:var(--mono)}
.mini-oms{height:5px;border-radius:3px;background:linear-gradient(to right,#1a6b6b 0%,#1a6b6b 25%,#d97706 25%,#d97706 50%,#ea580c 50%,#ea580c 72%,#dc2626 72%,#dc2626 100%);margin:9px 0 3px}

.hint{background:var(--teal-50);border-left:3px solid var(--teal-300);border-radius:var(--r-sm);padding:9px 12px;font-size:.74rem;color:var(--teal-700);margin-bottom:12px;line-height:1.5}

/* ── PERFIL ──────────────────────────────────────── */
.pav{width:68px;height:68px;border-radius:18px;background:linear-gradient(135deg,var(--teal-700),var(--teal-400));display:flex;align-items:center;justify-content:center;font-size:1.6rem;margin:0 auto 14px;box-shadow:0 8px 22px rgba(21,85,85,.3)}
.pstat{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);font-size:.81rem}
.pstat:last-child{border-bottom:none}
.pstat span{color:var(--t3)}
.pstat strong{font-family:var(--mono);color:var(--t1)}

/* ── EMPTY STATE ─────────────────────────────────── */
.empty{text-align:center;padding:44px 20px;color:var(--t4)}
.empty svg{width:38px;height:38px;stroke:var(--t4);fill:none;margin:0 auto 12px;display:block;opacity:.5}
.empty strong{font-size:.84rem;color:var(--t3)}
.empty p{font-size:.77rem;margin-top:4px}

/* ── MINI ACTIONS BAR ────────────────────────────── */
.mini-bar{display:flex;gap:7px;flex-wrap:wrap;margin-top:4px}

.footer{text-align:center;font-size:.6rem;color:var(--t4);padding:8px 12px 4px;font-family:var(--mono)}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-thumb{background:var(--border-md);border-radius:3px}

/* animation stagger on load */
.stagger-in>*{opacity:0;animation:staggerIn .3s ease forwards}
.stagger-in>*:nth-child(1){animation-delay:.05s}
.stagger-in>*:nth-child(2){animation-delay:.10s}
.stagger-in>*:nth-child(3){animation-delay:.15s}
.stagger-in>*:nth-child(4){animation-delay:.20s}
.stagger-in>*:nth-child(5){animation-delay:.25s}
