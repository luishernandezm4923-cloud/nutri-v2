let modo="", user={};
let fG="", fS="", fX="";
let pieC=null, evoC=null, allGrps=[];
let isDemo=false;

// ── Helpers ───────────────────────────────────────────────
const $  = id => document.getElementById(id);
const hoy = () => new Date().toISOString().split("T")[0];
const pct = (a,b) => b ? Math.round(a/b*100) : 0;
const ini = n  => n.split(" ").filter(Boolean).map(w=>w[0]).slice(0,2).join("").toUpperCase();

function spin(t="Procesando…"){ $("spinTxt").textContent=t; $("spinOv").classList.remove("h") }
function unspin(){ $("spinOv").classList.add("h") }
function toast(msg,ms=3200){
  const el=$("toastEl"); el.textContent=msg; el.classList.add("on");
  setTimeout(()=>el.classList.remove("on"),ms);
}
function openM(id){ $(id).classList.add("on") }
function closeM(id){ $(id).classList.remove("on") }

// ── Cálculos en frontend (idénticos al servidor) ──────────
function calcIMC(peso, talla) {
  const p=parseFloat(peso), t=parseFloat(talla);
  if(!p||!t||t<=0) return 0;
  return +((p/((t/100)**2)).toFixed(1));
}
function calcWHTR(cintura, talla) {
  const c=parseFloat(cintura), t=parseFloat(talla);
  if(!c||!t||t<=0) return null;
  return +((c/t).toFixed(2));
}
function calcEstado(imc){
  const v=parseFloat(imc);
  if(!v||v<=0) return "Normal";
  if(v<14)   return "Bajo Peso Severo";
  if(v<18.5) return "Bajo Peso";
  if(v<25)   return "Normal";
  if(v<30)   return "Sobrepeso";
  return "Obesidad";
}
function eBase(e){
  if(!e) return "Normal";
  const s=e.toLowerCase();
  if(s.includes("severo")||s.includes("bajo")) return "Bajo Peso";
  if(s.includes("sobre")) return "Sobrepeso";
  if(s.includes("obes"))  return "Obesidad";
  return "Normal";
}

const BC  = b=>({Normal:"bn","Bajo Peso":"bb",Sobrepeso:"bs",Obesidad:"bo"}[b]||"bn");
const AVC = b=>({Normal:"avn","Bajo Peso":"avb",Sobrepeso:"avs",Obesidad:"avo"}[b]||"avn");
const BLC = b=>({Normal:"bl-n","Bajo Peso":"bl-b",Sobrepeso:"bl-s",Obesidad:"bl-o"}[b]||"bl-n");
const EC  = b=>({Normal:"var(--green-500)","Bajo Peso":"var(--amber-500)",Sobrepeso:"var(--orange-500)",Obesidad:"var(--red-600)"}[b]||"var(--green-500)");
const PIE = ["#16a34a","#d97706","#ea580c","#dc2626"];

function autoRec(est, nom="El alumno"){
  const m={
    "Normal":"Estado nutricional adecuado. Mantener hábitos saludables y control anual.",
    "Bajo Peso":`${nom} requiere evaluación nutricional. Aumentar ingesta calórica supervisada. Consulta con nutricionista recomendada.`,
    "Bajo Peso Severo":`⚠️ DERIVAR URGENTE: ${nom} presenta bajo peso severo. Derivar al Centro de Salud San Andrés para evaluación médica inmediata.`,
    "Sobrepeso":"Iniciar actividad física regular. Reducir alimentos ultraprocesados y bebidas azucaradas. Consulta nutricional en 3 meses.",
    "Obesidad":`⚠️ DERIVAR URGENTE al Centro de Salud San Andrés. Evaluación médica completa. Iniciar programa de actividad física y dieta supervisada.`
  };
  return m[est]||m["Normal"];
}

// ── Calculadora rápida (dashboard) ───────────────────────
function calcQuick(){
  const p=parseFloat($("cPeso").value), t=parseFloat($("cTalla").value);
  const c=parseFloat($("cCintura").value)||null;
  const el=$("calcResult");
  if(p>0&&t>0){
    const imc=calcIMC(p,t), est=calcEstado(imc), eb=eBase(est);
    const whtr=c?calcWHTR(c,t):null, col=EC(eb);
    el.innerHTML=`
      <div>
        <div class="calc-imc-val" style="color:${col}">${imc}</div>
        <div class="calc-status" style="color:${col}">${est}</div>
        ${whtr?`<div class="calc-whtr">WHtR: ${whtr} · ${whtr>=0.5?"⚠ Riesgo":"Sin riesgo"}</div>`:""}
      </div>
      <div style="text-align:right;font-size:.64rem;opacity:.4;font-family:var(--mono)">
        ${p}kg / ${t}cm${c?` / ${c}cm`:""}
      </div>`;
  } else {
    el.innerHTML=`<div class="calc-placeholder">Ingrese peso y talla para calcular</div>`;
  }
}

