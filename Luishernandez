function goPage(p){
  document.querySelectorAll(".page").forEach(el=>el.classList.remove("ap"));
  document.querySelectorAll(".nbt").forEach(el=>el.classList.remove("on"));
  const pm={dash:"pgDash",control:"pgControl",alumnos:"pgAlumnos",detalle:"pgDetalle",perfil:"pgPerfil"};
  const nm={dash:"nDash",control:"nCtrl",alumnos:"nAlum",perfil:"nPerf"};
  if(pm[p]) $(pm[p]).classList.add("ap");
  if(nm[p]) $(nm[p]).classList.add("on");
  if(p==="alumnos"){ initFilters(); renderList(); }
  $("contentArea").scrollTop=0;
}

