// ── DATOS ─────────────────────────────────────────────────
async function loadData(){
  spin("Cargando datos del Google Sheet…");
  try{
    const r=await fetch(`${SHEET_URL}?action=getData&t=${Date.now()}`);
    if(!r.ok) throw 0;
    const d=await r.json();
    if(d.alumnos&&d.alumnos.length>0){
      parseData(d); isDemo=false;
      $("demoBanner").classList.remove("on");
      $("footerTxt").textContent=`Actualizado: ${new Date().toLocaleString("es-PE")} · ${DATA.length} alumnos`;
    } else throw 0;
  }catch{ loadDemo(); isDemo=true; $("demoBanner").classList.add("on"); $("footerTxt").textContent=`Modo demo · ${DATA.length} alumnos de muestra`; }
  unspin(); renderDash(); renderList(); renderPerfil();
}

function parseData(d){
  DATA=d.alumnos.map(a=>{
    // El servidor ya calcula imc/whtr/estado, pero verificamos en frontend también
    const imc   = Number(a.imc)  || calcIMC(a.peso, a.talla);
    const whtr  = a.whtr!=null   ? Number(a.whtr) : calcWHTR(a.cintura_cm, a.talla);
    const estado = a.estado      || calcEstado(imc);
    const eb     = eBase(estado);
    return{
      id:Number(a.id),nombre:String(a.nombre||""),grado:String(a.grado||""),
      seccion:String(a.seccion||"A"),edad:Number(a.edad)||0,sexo:String(a.sexo||""),
      peso:Number(a.peso)||0,talla:Number(a.talla)||0,
      imc, cintura_cm:a.cintura_cm?Number(a.cintura_cm):null, whtr, estado, eb,
      derivado:isTrue(a.derivado),mejoro:isTrue(a.mejoro),
      recomendacion:a.recomendacion||autoRec(estado,a.nombre),
      apoderado:String(a.apoderado||"No registrado"),telefono:String(a.telefono||""),
      historial:[]
    };
  });
  if(d.historial) DATA.forEach(a=>{
    a.historial=d.historial.filter(h=>Number(h.id_alumno)===a.id).map(h=>{
      const himc=Number(h.imc)||calcIMC(h.peso,h.talla);
      return{fecha:h.fecha,peso:Number(h.peso),talla:Number(h.talla),imc:himc,estado:h.estado||calcEstado(himc)};
    }).sort((x,y)=>x.fecha>y.fecha?1:-1);
    if(!a.historial.length&&a.imc) a.historial=[{fecha:hoy(),peso:a.peso,talla:a.talla,imc:a.imc,estado:a.estado}];
  });
}

const isTrue = v => v===true||String(v).toUpperCase()==="TRUE";
function recargar(){ loadData(); toast("Actualizando datos…"); }

